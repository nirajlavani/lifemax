# --- Telegram bot ---
# Create a bot via @BotFather, then paste the token here.
TELEGRAM_BOT_TOKEN=your-bot-token-here
# Your numeric Telegram user id (talk to @userinfobot to get it).
# Only this user is allowed to interact with the bot.
TELEGRAM_USER_ID=123456789

# --- OpenRouter ---
# Get a key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
# Cheap, fast model with strict json_schema support. Override as you like.
# Examples: deepseek/deepseek-chat, google/gemini-flash-1.5, openai/gpt-4o-mini
OPENROUTER_MODEL=deepseek/deepseek-chat

# --- Local server ---
# Bound to 127.0.0.1 only. Pick any free port.
SERVER_HOST=127.0.0.1
SERVER_PORT=8765
# Shared secret required by the local CLI bridge for POSTs to /api/dispatch.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
LIFEMAX_DISPATCH_TOKEN=replace-me-with-a-random-32-byte-token

# --- Misc ---
# Optional override of the auto-detected location for weather (decimal degrees).
# Leave blank to auto-detect via ipapi.co.
LIFEMAX_LATITUDE=
LIFEMAX_LONGITUDE=
LIFEMAX_TIMEZONE=America/New_York
LOG_LEVEL=INFO
